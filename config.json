{
  "workspaceName": ".workspace",
  "branchNamePattern": "issue_#<issue番号>",
  "implementationDirectory": "../<リポジトリ名>-branches/",
  "implementationLoopCount": 3,
  "autoPollingInterval": "5m",
  "baseBranch": "main",
  "builtinAllowedCommands": [
    "npm install", "npm ci", "npm test",
    "go build", "go test", "go mod tidy", "go mod download",
    "git log", "git add", "git commit", "git diff", "git status", "git stash", "git --no-pager diff", "git --no-pager grep",
    "command -v", "cd", "true",
    "ls", "dir", "cat", "type", "more", "head", "echo", "sed", "set", "pwd", "grep", "find", "tee", "wc",
    "get-childitem", "get-content", "select-object", "select-string"
  ],
  "builtinAllowedPaths": [
    "~/.copilot/session-state/*/plan.md",
    "~/dev/go/src/github.com/coco-papiyon/korocon-branches/*/cmd/korocon/config_test.go"
  ]
}
